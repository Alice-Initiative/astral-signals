# Core storage
# Example Windows: S:\AstralSignals
# Example Linux: /home/you/AstralSignals
ASTRAL_SIGNALS_HOME=/path/to/AstralSignals
ASTRAL_SIGNALS_VENDOR_ROOT=/path/to/AstralSignals/vendors

# Ollama
# Example Windows binary: S:\Ollama\app\ollama.exe
# Example Linux binary: /usr/local/bin/ollama or just ollama if it is on PATH
ASTRAL_SIGNALS_OLLAMA_BIN=ollama
ASTRAL_SIGNALS_OLLAMA_MODELS=/path/to/.ollama/models
ASTRAL_SIGNALS_OLLAMA_HOST=http://127.0.0.1:11435
ASTRAL_SIGNALS_OLLAMA_MODEL=qwen3:4b
ASTRAL_SIGNALS_MUSICGEN_MODEL=facebook/musicgen-small

# ACE-Step
ASTRAL_SIGNALS_ACE_STEP_REPO=/path/to/AstralSignals/vendors/ACE-Step-1.5
ASTRAL_SIGNALS_ACE_STEP_API=/path/to/AstralSignals/vendors/ACE-Step-1.5/.venv/bin/acestep-api
ASTRAL_SIGNALS_ACE_STEP_HOST=http://127.0.0.1:8001
ASTRAL_SIGNALS_ACE_STEP_MODEL=acestep-v15-turbo
ASTRAL_SIGNALS_ACE_STEP_LM_MODEL=acestep-5Hz-lm-1.7B
ASTRAL_SIGNALS_ACE_STEP_LONG_LYRIC_LM_MODEL=acestep-5Hz-lm-0.6B
ASTRAL_SIGNALS_ACE_STEP_CHECKPOINTS=/path/to/AstralSignals/models/ace-step
ASTRAL_SIGNALS_ACE_STEP_STARTUP_TIMEOUT=150
ASTRAL_SIGNALS_ACE_STEP_SERVER_TIMEOUT=10800
ASTRAL_SIGNALS_ACE_STEP_DISABLE_THINKING_AFTER=120

# Voicebox
ASTRAL_SIGNALS_VOICEBOX_REPO=/path/to/AstralSignals/vendors/voicebox
ASTRAL_SIGNALS_VOICEBOX_HOST=http://127.0.0.1:17493

# Optional engine repos
ASTRAL_SIGNALS_HEARTMULA_REPO=/path/to/AstralSignals/vendors/heartlib
ASTRAL_SIGNALS_HEARTMULA_VENV=/path/to/AstralSignals/vendors/heartlib/.venv
ASTRAL_SIGNALS_HEARTMULA_CKPT=/path/to/AstralSignals/models/heartmula/ckpt
ASTRAL_SIGNALS_HEARTMULA_MODEL=HeartMuLa-oss-3B-happy-new-year
ASTRAL_SIGNALS_HEARTMULA_VERSION=3B
ASTRAL_SIGNALS_SONGGENERATION_REPO=/path/to/AstralSignals/vendors/SongGeneration
ASTRAL_SIGNALS_SONGGENERATION_VENV=/path/to/AstralSignals/vendors/SongGeneration/.venv
ASTRAL_SIGNALS_SONGGENERATION_RUNTIME=/path/to/AstralSignals/models/songgeneration/runtime
ASTRAL_SIGNALS_SONGGENERATION_MODELS=/path/to/AstralSignals/models/songgeneration
ASTRAL_SIGNALS_SONGGENERATION_MODEL=songgeneration_v2_large
ASTRAL_SIGNALS_SONGGENERATION_TIMEOUT=7200
ASTRAL_SIGNALS_SONGGENERATION_LOW_MEM=true
ASTRAL_SIGNALS_SONGGENERATION_USE_FLASH_ATTN=false
ASTRAL_SIGNALS_YUE_REPO=/path/to/AstralSignals/vendors/YuE
ASTRAL_SIGNALS_AUDIOCRAFT_REPO=/path/to/AstralSignals/vendors/audiocraft
ASTRAL_SIGNALS_STABLE_AUDIO_REPO=/path/to/AstralSignals/vendors/stable-audio-tools
ASTRAL_SIGNALS_SOULX_REPO=/path/to/AstralSignals/vendors/SoulX-Singer
ASTRAL_SIGNALS_DIFFSINGER_REPO=/path/to/AstralSignals/vendors/DiffSinger

# Optional cache overrides
VOICEBOX_MODELS_DIR=/path/to/AstralSignals/cache/huggingface/voicebox-hf
HF_HUB_CACHE=/path/to/AstralSignals/cache/huggingface/voicebox-hf
HF_HOME=/path/to/AstralSignals/cache/huggingface
TRANSFORMERS_CACHE=/path/to/AstralSignals/cache/huggingface/voicebox-hf
TEMP=/path/to/AstralSignals/cache/tmp
TMP=/path/to/AstralSignals/cache/tmp
