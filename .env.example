ASTRAL_SIGNALS_HOME=S:\AstralSignals
ASTRAL_SIGNALS_VENDOR_ROOT=S:\AstralSignals\vendors

# Ollama
ASTRAL_SIGNALS_OLLAMA_BIN=S:\Ollama\app\ollama.exe
ASTRAL_SIGNALS_OLLAMA_MODELS=S:\Ollama\.ollama\models
ASTRAL_SIGNALS_OLLAMA_HOST=http://127.0.0.1:11435
ASTRAL_SIGNALS_OLLAMA_MODEL=qwen3:4b
ASTRAL_SIGNALS_MUSICGEN_MODEL=facebook/musicgen-small

# ACE-Step
ASTRAL_SIGNALS_ACE_STEP_REPO=S:\AstralSignals\vendors\ACE-Step-1.5
ASTRAL_SIGNALS_ACE_STEP_API=S:\AstralSignals\vendors\ACE-Step-1.5\.venv\Scripts\acestep-api.exe
ASTRAL_SIGNALS_ACE_STEP_HOST=http://127.0.0.1:8001
ASTRAL_SIGNALS_ACE_STEP_MODEL=acestep-v15-turbo
ASTRAL_SIGNALS_ACE_STEP_LM_MODEL=acestep-5Hz-lm-1.7B
ASTRAL_SIGNALS_ACE_STEP_LONG_LYRIC_LM_MODEL=acestep-5Hz-lm-0.6B
ASTRAL_SIGNALS_ACE_STEP_CHECKPOINTS=S:\AstralSignals\models\ace-step
ASTRAL_SIGNALS_ACE_STEP_STARTUP_TIMEOUT=150
ASTRAL_SIGNALS_ACE_STEP_SERVER_TIMEOUT=10800
ASTRAL_SIGNALS_ACE_STEP_DISABLE_THINKING_AFTER=120

# Voicebox
ASTRAL_SIGNALS_VOICEBOX_REPO=S:\AstralSignals\vendors\voicebox
ASTRAL_SIGNALS_VOICEBOX_HOST=http://127.0.0.1:17493

# Optional engine repos
ASTRAL_SIGNALS_HEARTMULA_REPO=S:\AstralSignals\vendors\heartlib
ASTRAL_SIGNALS_HEARTMULA_VENV=S:\AstralSignals\vendors\heartlib\.venv
ASTRAL_SIGNALS_HEARTMULA_CKPT=S:\AstralSignals\models\heartmula\ckpt
ASTRAL_SIGNALS_HEARTMULA_MODEL=HeartMuLa-oss-3B-happy-new-year
ASTRAL_SIGNALS_HEARTMULA_VERSION=3B
ASTRAL_SIGNALS_SONGGENERATION_REPO=S:\AstralSignals\vendors\SongGeneration
ASTRAL_SIGNALS_SONGGENERATION_VENV=S:\AstralSignals\vendors\SongGeneration\.venv
ASTRAL_SIGNALS_SONGGENERATION_RUNTIME=S:\AstralSignals\models\songgeneration\runtime
ASTRAL_SIGNALS_SONGGENERATION_MODELS=S:\AstralSignals\models\songgeneration
ASTRAL_SIGNALS_SONGGENERATION_MODEL=songgeneration_v2_large
ASTRAL_SIGNALS_SONGGENERATION_TIMEOUT=7200
ASTRAL_SIGNALS_SONGGENERATION_LOW_MEM=true
ASTRAL_SIGNALS_SONGGENERATION_USE_FLASH_ATTN=false
ASTRAL_SIGNALS_YUE_REPO=S:\AstralSignals\vendors\YuE
ASTRAL_SIGNALS_AUDIOCRAFT_REPO=S:\AstralSignals\vendors\audiocraft
ASTRAL_SIGNALS_STABLE_AUDIO_REPO=S:\AstralSignals\vendors\stable-audio-tools
ASTRAL_SIGNALS_SOULX_REPO=S:\AstralSignals\vendors\SoulX-Singer
ASTRAL_SIGNALS_DIFFSINGER_REPO=S:\AstralSignals\vendors\DiffSinger

# Optional cache overrides
VOICEBOX_MODELS_DIR=S:\AstralSignals\cache\huggingface\voicebox-hf
HF_HUB_CACHE=S:\AstralSignals\cache\huggingface\voicebox-hf
HF_HOME=S:\AstralSignals\cache\huggingface
TRANSFORMERS_CACHE=S:\AstralSignals\cache\huggingface\voicebox-hf
TEMP=S:\AstralSignals\cache\tmp
TMP=S:\AstralSignals\cache\tmp
